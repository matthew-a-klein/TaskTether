    "connect.description" : {
      "comment" : "Short description shown on the connect screen below the app name.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "زامن تذكيرات Apple مع مهام Google بسلاسة."
