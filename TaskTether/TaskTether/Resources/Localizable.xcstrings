    "error.reminders.createlist" : {
      "comment" : "Error shown when the TaskTether list cannot be created in Reminders. %@ is replaced with the system error description.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعذّر إنشاء قائمة TaskTether: %@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Could not create TaskTether list: %@"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nem sikerült létrehozni a TaskTether listát: %@"
          }
        }
      }
    },
    "error.reminders.denied.v12" : {
      "comment" : "Error shown on macOS 12–13 (Monterey/Ventura) when Reminders access is denied. 'System Preferences' is the correct name on those versions.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم رفض الوصول إلى التذكيرات. يُرجى التفعيل من تفضيلات النظام ← الأمان والخصوصية ← التذكيرات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reminders access denied. Please enable in System Preferences → Security & Privacy → Reminders."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az Emlékeztetők hozzáférése megtagadva. Engedélyezd a Rendszerbeállítások → Biztonság és adatvédelem → Emlékeztetők menüpontban."
          }
        }
      }
    },
    "error.reminders.denied.v14" : {
      "comment" : "Error shown on macOS 14+ (Sonoma and later) when Reminders access is denied. 'System Settings' is the correct name from macOS 13 onwards.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم رفض الوصول إلى التذكيرات. يُرجى التفعيل من إعدادات النظام ← الخصوصية ← التذكيرات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reminders access denied. Please enable in System Settings → Privacy → Reminders."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az Emlékeztetők hozzáférése megtagadva. Engedélyezd a Rendszerbeállítások → Adatvédelem → Emlékeztetők menüpontban."
          }
        }
      }
    },
